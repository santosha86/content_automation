# Copy to .env and fill in. .env is gitignored — NEVER commit real keys.

# ---- LLM: one API for all models via OpenRouter (recommended) ----
# provider: "openrouter" (one recharge, all models), "anthropic", or "ollama" (free local)
LLM_PROVIDER=openrouter
# OpenRouter — powers text + vision when a station's provider is "openrouter" (Config page).
# Until this is set, "openrouter" stations fall back to ANTHROPIC_API_KEY, then local ollama.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_VISION_MODEL=anthropic/claude-sonnet-4.5
# Anthropic direct (optional fallback / alternative provider)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
# Local, free (used when provider is "ollama")
OLLAMA_MODEL=gpt-oss

# ---- Voice ----
# kokoro (free, local) is the default — see config/settings.yaml voice.provider.
# Only needed if you switch voice.provider to "elevenlabs":
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb

# ---- Media sources ----
# Pexels stock b-roll (free key: pexels.com/api). Empty = generated backgrounds
PEXELS_API_KEY=
# Tavily web search (Strategist ai_news lane). Get a key: tavily.com
TAVILY_API_KEY=
# HuggingFace token for local FLUX image gen (gated FLUX.1-schnell). Read token.
HF_TOKEN=
MFLUX_ENABLED=1

# ---- Publisher (Phase C) — add when ready. Dry-run unless PUBLISH_LIVE=1 AND keys present ----
PUBLISH_LIVE=
# YouTube Data API v3 (OAuth desktop client + youtube.upload scope)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY=private
YOUTUBE_CATEGORY_ID=28
# Instagram Graph API (Reels) — Business/Creator account + a PUBLIC https url to the video
IG_USER_ID=
IG_ACCESS_TOKEN=
IG_PUBLIC_VIDEO_URL=

# ---- Analytics (Phase E) — sample data until this is set + analytics._fetch_live() wired ----
ANALYTICS_LIVE=

# ---- Social posts (LinkedIn / X via Typefully) — optional ----
TYPEFULLY_API_KEY=

# ---- Motion video-gen (fal.ai) — the "OpenRouter for media", one key for Kling/LTX/Wan ----
# Put the KEY here (secret). The ON/OFF toggle + model + per-video cap live in
# config/settings.yaml -> videogen (enabled/max_shots/model_i2v) so you can change them
# anytime with no code edits. Nothing spends unless FAL_KEY is set AND videogen.enabled is
# true. VIDEOGEN_ENABLED below is an OPTIONAL one-off override (e.g. VIDEOGEN_ENABLED=0 to
# force off for a single run); leave empty to let settings.yaml decide.
FAL_KEY=
VIDEOGEN_ENABLED=
