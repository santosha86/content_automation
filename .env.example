# LLM (script writing + topic ranking)
# provider: "anthropic" (recommended) or "ollama" (free, local)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-opus-4-8
# Used when LLM_PROVIDER=ollama
OLLAMA_MODEL=gpt-oss

# Voice: kokoro (free, local) is the default — see config/settings.yaml voice.provider.
# Only needed if you switch voice.provider to "elevenlabs" in config/settings.yaml:
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb

# Pexels stock b-roll (free key: pexels.com/api). Empty = generated gradient backgrounds
PEXELS_API_KEY=

# OpenRouter (free API credits rung — used when a station's provider is "openrouter"
# on the dashboard Config page). Free key: openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free
